# ============================================
# PANDA-NG PLATFORM ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

NODE_ENV=development

# ── DATABASE ──────────────────────────────────
DATABASE_URL=postgresql://pandang:password@localhost:5432/pandang_db
DATABASE_DIRECT_URL=postgresql://pandang:password@localhost:5432/pandang_db

# ── REDIS ─────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_NODES=

# ── JWT ───────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── SERVICE URLS ──────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
WALLET_SERVICE_URL=http://localhost:3002
JACKPOT_SERVICE_URL=http://localhost:3003
REALTIME_SERVICE_URL=http://localhost:3004
REWARDS_SERVICE_URL=http://localhost:3005
NOTIFICATIONS_SERVICE_URL=http://localhost:3006
FRAUD_SERVICE_URL=http://localhost:3007
ADMIN_API_SERVICE_URL=http://localhost:3008

# ── PAYMENT GATEWAYS ──────────────────────────
GCASH_API_KEY=your-gcash-api-key
GCASH_SECRET=your-gcash-secret
GCASH_WEBHOOK_SECRET=your-gcash-webhook-secret

MAYA_API_KEY=your-maya-api-key
MAYA_SECRET=your-maya-secret
MAYA_PUBLIC_KEY=your-maya-public-key

GRABPAY_MERCHANT_ID=your-grabpay-merchant-id
GRABPAY_SECRET=your-grabpay-secret

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── MONITORING ────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── FIREBASE (Push Notifications) ─────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase@project.iam.gserviceaccount.com

# ── SECURITY ──────────────────────────────────
ADMIN_API_KEY=your-internal-admin-api-key-min-32-chars
INTERNAL_API_KEY=your-internal-service-api-key-min-32-chars
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── APPS ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3004
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SEEDING (DEV ONLY) ────────────────────────
SEED_ADMIN_PASSWORD=dev-admin-password-change-me
SEED_PLAYER_PASSWORD=dev-player-password-change-me
